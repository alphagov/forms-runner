<nav aria-label="<%= t("language_switcher.nav_label") %>" class="app-language-switcher">
  <ul class="govuk-list">
    <% @languages.each do |language| %>
      <li>
        <% if is_current_locale?(language) %>
          <span lang="<%= language %>" aria-current="true"><%= language_local_name(language) %></span>
        <% else %>
          <%= govuk_link_to(language_local_name(language), url_for(locale: locale(language)), lang: language, hreflang: language, rel: "alternate") %>
        <% end %>
      </li>
    <% end %>
  </ul>
</nav>
